<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Sore Space Clicker</title>
    <style>
        body {
            background-color: #0b0b0f;
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            height: 100vh;
            margin: 0;
            padding: 20px 0;
            box-sizing: border-box;
            overflow: hidden;
            user-select: none;
            -webkit-user-select: none;
            touch-action: manipulation;
        }

        header {
            text-align: center;
        }

        h1 {
            font-size: 2.5rem;
            margin: 0 0 5px 0;
            color: #ff2a85;
            text-shadow: 0 0 10px #ff2a85, 0 0 20px #ff2a85;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .subtitle {
            font-size: 0.9rem;
            color: #a0a0c0;
        }

        #score-container {
            font-size: 2.2rem;
            font-weight: bold;
            margin: 15px 0;
            color: #fff;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
        }

        /* Responsive SVG container */
        .logo-container {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            max-height: 40vh;
        }

        #game-logo {
            width: 70vw;
            height: 70vw;
            max-width: 260px;
            max-height: 260px;
            cursor: pointer;
            filter: drop-shadow(0 0 15px rgba(255, 42, 133, 0.8));
            transition: transform 0.05s ease;
            -webkit-tap-highlight-color: transparent;
        }

        #game-logo:active {
            transform: scale(0.90);
        }

        #shop-container {
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid #ff2a85;
            border-radius: 16px;
            padding: 15px;
            box-shadow: 0 0 15px rgba(255, 42, 133, 0.2);
            text-align: center;
            width: 85%;
            max-width: 320px;
            margin-bottom: 20px;
        }

        #shop-container h3 {
            margin: 0 0 10px 0;
            color: #ff2a85;
            text-transform: uppercase;
            font-size: 1.1rem;
            letter-spacing: 1px;
        }

        .upgrade-btn {
            background-color: #ff2a85;
            color: white;
            border: none;
            padding: 14px 20px;
            font-size: 1rem;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(255, 42, 133, 0.5);
            transition: all 0.2s ease;
            width: 100%;
            -webkit-tap-highlight-color: transparent;
        }

        .upgrade-btn:active {
            background-color: #ff559f;
            transform: scale(0.98);
        }

        .upgrade-btn:disabled {
            background-color: #333;
            color: #777;
            box-shadow: none;
        }

        .stats {
            margin-top: 8px;
            font-size: 0.85rem;
            color: #a0a0c0;
        }

        /* Floating numbers animation */
        .floating-num {
            position: absolute;
            color: #ff2a85;
            font-weight: bold;
            font-size: 1.8rem;
            pointer-events: none;
            animation: floatUp 0.6s ease-out forwards;
            text-shadow: 0 0 8px #ff2a85;
        }

        @keyframes floatUp {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(-100px) scale(1.3);
            }
        }
    </style>
</head>
<body>

    <header>
        <h1>sore space</h1>
        <div class="subtitle">Tap the neon monster!</div>
    </header>

    <div id="score-container"><span id="score">0</span> pts</div>

    <div class="logo-container">
        <svg id="game-logo" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <rect x="45" y="35" width="110" height="130" rx="20" fill="none" stroke="#ff2a85" stroke-width="6" />
            
            <line x1="50" y1="60" x2="150" y2="60" stroke="#ff2a85" stroke-width="4" />
            
            <rect x="75" y="75" width="8" height="30" rx="3" fill="none" stroke="#ff2a85" stroke-width="4" />
            
            <rect x="117" y="75" width="8" height="30" rx="3" fill="none" stroke="#ff2a85" stroke-width="4" />
            
            <path d="M52 110 Q 100 145 148 110" fill="none" stroke="#ff2a85" stroke-width="4" />
            
            <polygon points="75,120 83,120 79,135" fill="none" stroke="#ff2a85" stroke-width="4" stroke-linejoin="round" />
            
            <polygon points="117,120 125,120 121,135" fill="none" stroke="#ff2a85" stroke-width="4" stroke-linejoin="round" />
            
            <path d="M42 165 L48 155 L54 165 L60 155 L66 168 L72 155 L78 165 L84 155 L90 168 L96 155 L102 165 L108 155 L114 168 L120 155 L126 165 L132 155 L138 168 L144 155 L150 165 L158 155" fill="none" stroke="#ff2a85" stroke-width="4" stroke-linecap="round" />
        </svg>
    </div>

    <div id="shop-container">
        <h3>Upgrades</h3>
        <button id="upgrade-btn" class="upgrade-btn" onclick="buyUpgrade()">
            Upgrade Clicks (Cost: <span id="upgrade-cost">15</span>)
        </button>
        <div class="stats">Current Power: +<span id="click-power">1</span></div>
    </div>

    <script>
        let score = 0;
        let clickPower = 1;
        let upgradeCost = 15;

        const scoreEl = document.getElementById('score');
        const upgradeBtn = document.getElementById('upgrade-btn');
        const upgradeCostEl = document.getElementById('upgrade-cost');
        const clickPowerEl = document.getElementById('click-power');
        const logo = document.getElementById('game-logo');

        // Touch event listener for mobile to prevent delay
        logo.addEventListener('touchstart', function(event) {
            event.preventDefault(); // Prevents double-tap zooming
            score += clickPower;
            updateDisplay();
            
            // Get touch coordinate
            const touch = event.touches[0];
            createFloatingNumber(touch.clientX, touch.clientY, `+${clickPower}`);
        }, { passive: false });

        function buyUpgrade() {
            if (score >= upgradeCost) {
                score -= upgradeCost;
                clickPower += 1;
                upgradeCost = Math.round(upgradeCost * 1.6);
                updateDisplay();
            }
        }

        function updateDisplay() {
            scoreEl.textContent = score;
            upgradeCostEl.textContent = upgradeCost;
            clickPowerEl.textContent = clickPower;

            if (score < upgradeCost) {
                upgradeBtn.disabled = true;
            } else {
                upgradeBtn.disabled = false;
            }
        }

        function createFloatingNumber(x, y, text) {
            const num = document.createElement('div');
            num.className = 'floating-num';
            num.textContent = text;
            num.style.left = `${x - 10}px`;
            num.style.top = `${y - 20}px`;
            document.body.appendChild(num);

            setTimeout(() => {
                num.remove();
            }, 600);
        }

        updateDisplay();
    </script>
</body>
</html>
